# SwiftFormat config — PPoker
--swiftversion 6.0
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--commas inline
--semicolons never
--trimwhitespace always
--stripunusedargs closure-only
--self remove
--header strip
--exclude .build,.swiftpm
